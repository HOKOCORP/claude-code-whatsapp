#!/usr/bin/env node
/**
 * cc-usage-monitor — USD wallet management for channel users.
 *
 * New users start at $0 (blocked). Admin tops up in USD.
 * Each API call deducts estimated cost based on Anthropic model pricing.
 * Balance can go negative on overshoot.
 *
 * Commands:
 *   cc-usage-monitor status                       All users' balances
 *   cc-usage-monitor check <userId>               Detailed view
 *   cc-usage-monitor add <userId> <usd> [note]    Top up wallet (USD)
 *   cc-usage-monitor daily <userId>               Daily breakdown
 *   cc-usage-monitor history <userId>             Admin action log
 *   cc-usage-monitor set-warn <usd>               Low-balance warning ($)
 *
 * Data: ~/.ccm/usage/
 */

const fs = require("fs");
const path = require("path");
const os = require("os");

const USAGE_DIR = path.join(os.homedir(), ".ccm", "usage");
const CONFIG_FILE = path.join(USAGE_DIR, "limits.json");
fs.mkdirSync(USAGE_DIR, { recursive: true });

function loadConfig() {
  try { return JSON.parse(fs.readFileSync(CONFIG_FILE, "utf8")); }
  catch { return { warn_balance: 1.00 }; }
}
function saveConfig(c) { fs.writeFileSync(CONFIG_FILE, JSON.stringify(c, null, 2)); }

function loadUsage(userId) {
  try { return JSON.parse(fs.readFileSync(path.join(USAGE_DIR, `${userId}.json`), "utf8")); }
  catch { return { userId, balance: 0, total_added: 0, total_cost: 0, history: [], months: {} }; }
}
function saveUsage(userId, u) { fs.writeFileSync(path.join(USAGE_DIR, `${userId}.json`), JSON.stringify(u, null, 2)); }

function monthKey() { return new Date().toISOString().slice(0, 7); }
function todayKey() { return new Date().toISOString().slice(0, 10); }

function fmtTok(n) {
  const a = Math.abs(n);
  const s = n < 0 ? "-" : "";
  if (a >= 1e6) return `${s}${(a / 1e6).toFixed(1)}M`;
  if (a >= 1e3) return `${s}${Math.round(a / 1e3)}K`;
  return String(n);
}

function fmtUSD(n) {
  if (n < 0) return `-$${Math.abs(n).toFixed(2)}`;
  return `$${n.toFixed(2)}`;
}

// ── Commands ──

function cmdStatus() {
  const config = loadConfig();
  const files = fs.readdirSync(USAGE_DIR).filter(f => f.endsWith(".json") && f !== "limits.json");

  if (files.length === 0) {
    console.log("No users yet. Use: cc-usage-monitor add <userId> <usd>");
    return;
  }

  console.log(`\n  Wallet Balances\n`);
  console.log(`  ${"User".padEnd(25)} ${"Balance".padStart(10)} ${"Added".padStart(10)} ${"Spent".padStart(10)} ${"Status".padStart(10)}`);
  console.log(`  ${"─".repeat(25)} ${"─".repeat(10)} ${"─".repeat(10)} ${"─".repeat(10)} ${"─".repeat(10)}`);

  for (const f of files) {
    const userId = f.replace(".json", "");
    const u = loadUsage(userId);
    let status = "ok";
    if ((u.balance || 0) <= 0) status = u.balance < 0 ? "NEGATIVE" : "EMPTY";
    else if ((u.balance || 0) <= (config.warn_balance || 1)) status = "LOW";

    console.log(`  ${userId.padEnd(25)} ${fmtUSD(u.balance || 0).padStart(10)} ${fmtUSD(u.total_added || 0).padStart(10)} ${fmtUSD(u.total_cost || 0).padStart(10)} ${status.padStart(10)}`);
  }
  console.log(`\n  Low-balance warning: ${fmtUSD(config.warn_balance || 1)}\n`);
}

function cmdCheck(userId) {
  const u = loadUsage(userId);
  const month = monthKey();
  const mo = u.months?.[month] || { input_tokens: 0, output_tokens: 0, cache_5m: 0, cache_1h: 0, cache_read: 0, models: {} };

  console.log(`\n  User: ${userId}`);
  console.log(`  ──────────────────────────────`);
  console.log(`  Balance:    ${fmtUSD(u.balance || 0)}${(u.balance || 0) <= 0 ? " (BLOCKED)" : ""}`);
  console.log(`  Added:      ${fmtUSD(u.total_added || 0)}`);
  console.log(`  Spent:      ${fmtUSD(u.total_cost || 0)}`);
  console.log(`  ──────────────────────────────`);
  console.log(`  This month (${month}):`);
  console.log(`    Input:       ${fmtTok(mo.input_tokens || 0)}`);
  console.log(`    Output:      ${fmtTok(mo.output_tokens || 0)}`);
  console.log(`    Cache 5m:    ${fmtTok(mo.cache_5m || 0)}`);
  console.log(`    Cache 1h:    ${fmtTok(mo.cache_1h || 0)}`);
  console.log(`    Cache read:  ${fmtTok(mo.cache_read || 0)}`);

  if (mo.models && Object.keys(mo.models).length > 0) {
    console.log(`  ──────────────────────────────`);
    console.log(`  Per model this month:`);
    for (const [model, mu] of Object.entries(mo.models)) {
      const short = model.replace("claude-", "").replace(/\[.*\]/, "");
      console.log(`    ${short}: in=${fmtTok(mu.input_tokens)} out=${fmtTok(mu.output_tokens)} 5m=${fmtTok(mu.cache_5m || 0)} 1h=${fmtTok(mu.cache_1h || 0)} read=${fmtTok(mu.cache_read || 0)}`);
    }
  }

  if (u.history && u.history.length > 0) {
    console.log(`  ──────────────────────────────`);
    console.log(`  Recent:`);
    for (const h of u.history.slice(-5)) {
      const note = h.note ? ` — ${h.note}` : "";
      console.log(`    ${h.date} ${h.action} ${fmtUSD(h.amount)}${note}`);
    }
  }
  console.log();
}

function cmdAdd(userId, amount, note) {
  const u = loadUsage(userId);
  const before = u.balance || 0;
  u.balance = Math.round((before + amount) * 10000) / 10000;
  u.total_added = Math.round(((u.total_added || 0) + amount) * 10000) / 10000;
  if (!u.history) u.history = [];
  u.history.push({ date: todayKey(), action: "top-up", amount, note: note || "" });
  saveUsage(userId, u);

  console.log(`  Added ${fmtUSD(amount)} to ${userId}`);
  console.log(`  Balance: ${fmtUSD(before)} → ${fmtUSD(u.balance)}`);
  if (before <= 0 && u.balance > 0) console.log(`  User is now UNBLOCKED`);
}

function cmdDaily(userId) {
  const month = monthKey();
  const u = loadUsage(userId);
  const mo = u.months?.[month];

  if (!mo || !mo.daily || Object.keys(mo.daily).length === 0) {
    console.log(`No daily data for ${userId} in ${month}.`);
    return;
  }

  console.log(`\n  Daily Breakdown — ${userId} — ${month}\n`);
  console.log(`  ${"Date".padEnd(14)} ${"Input".padStart(10)} ${"Output".padStart(10)} ${"Cache 5m".padStart(10)} ${"Cache 1h".padStart(10)} ${"Cache Rd".padStart(10)}`);
  console.log(`  ${"─".repeat(14)} ${"─".repeat(10)} ${"─".repeat(10)} ${"─".repeat(10)} ${"─".repeat(10)} ${"─".repeat(10)}`);

  const days = Object.keys(mo.daily).sort();
  for (const d of days) {
    const dd = mo.daily[d];
    const total = (dd.input_tokens || 0) + (dd.output_tokens || 0) + (dd.cache_5m || 0) + (dd.cache_1h || 0);
    if (total === 0) continue;
    console.log(`  ${d.padEnd(14)} ${fmtTok(dd.input_tokens || 0).padStart(10)} ${fmtTok(dd.output_tokens || 0).padStart(10)} ${fmtTok(dd.cache_5m || 0).padStart(10)} ${fmtTok(dd.cache_1h || 0).padStart(10)} ${fmtTok(dd.cache_read || 0).padStart(10)}`);
  }
  console.log(`\n  Balance: ${fmtUSD(u.balance || 0)} | Total spent: ${fmtUSD(u.total_cost || 0)}\n`);
}

function cmdHistory(userId) {
  const u = loadUsage(userId);
  if (!u.history || u.history.length === 0) {
    console.log(`No history for ${userId}.`);
    return;
  }

  console.log(`\n  Wallet History — ${userId}\n`);
  console.log(`  ${"Date".padEnd(14)} ${"Action".padEnd(10)} ${"Amount".padStart(10)} ${"Note"}`);
  console.log(`  ${"─".repeat(14)} ${"─".repeat(10)} ${"─".repeat(10)} ${"─".repeat(30)}`);
  for (const h of u.history) {
    console.log(`  ${h.date.padEnd(14)} ${h.action.padEnd(10)} ${fmtUSD(h.amount).padStart(10)} ${h.note || ""}`);
  }
  console.log(`\n  Balance: ${fmtUSD(u.balance || 0)}\n`);
}

function cmdSetWarn(usd) {
  const config = loadConfig();
  config.warn_balance = parseFloat(usd);
  saveConfig(config);
  console.log(`Low-balance warning: ${fmtUSD(config.warn_balance)}`);
}

// ── Main ──

const [cmd, ...args] = process.argv.slice(2);

switch (cmd) {
  case "status": cmdStatus(); break;
  case "check":
    if (!args[0]) { console.error("Usage: cc-usage-monitor check <userId>"); process.exit(1); }
    cmdCheck(args[0]); break;
  case "add":
    if (!args[0] || !args[1]) { console.error("Usage: cc-usage-monitor add <userId> <usd> [note]"); process.exit(1); }
    cmdAdd(args[0], parseFloat(args[1]), args.slice(2).join(" ")); break;
  case "daily":
    if (!args[0]) { console.error("Usage: cc-usage-monitor daily <userId>"); process.exit(1); }
    cmdDaily(args[0]); break;
  case "history":
    if (!args[0]) { console.error("Usage: cc-usage-monitor history <userId>"); process.exit(1); }
    cmdHistory(args[0]); break;
  case "set-warn":
    if (!args[0]) { console.error("Usage: cc-usage-monitor set-warn <usd>"); process.exit(1); }
    cmdSetWarn(args[0]); break;
  default:
    console.log("cc-usage-monitor — USD wallet for channel users\n");
    console.log("New users start at $0 (blocked). Admin tops up in USD.\n");
    console.log("Commands:");
    console.log("  status                       All users' balances");
    console.log("  check <userId>               Detailed view");
    console.log("  add <userId> <usd> [note]    Top up wallet in USD");
    console.log("  daily <userId>               Daily token breakdown");
    console.log("  history <userId>             Wallet transaction log");
    console.log("  set-warn <usd>               Low-balance warning threshold");
    console.log("\nExamples:");
    console.log("  cc-usage-monitor add 85258080138 50 'April project'");
    console.log("  cc-usage-monitor add 120363XXXXX 100 'Client X group'");
    console.log("  cc-usage-monitor status");
    console.log("\nPricing based on current Anthropic API rates.");
    console.log("Data: ~/.ccm/usage/");
}
