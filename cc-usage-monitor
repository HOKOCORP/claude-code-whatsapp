#!/usr/bin/env node
/**
 * cc-usage-monitor — CLI tool for channel token usage and monthly budgets.
 *
 * Usage:
 *   cc-usage-monitor status                       Monthly overview for all users
 *   cc-usage-monitor check <userId>               Detailed usage for one user
 *   cc-usage-monitor daily <userId>               Daily breakdown for current month
 *   cc-usage-monitor set-budget <tokens>           Set default monthly budget
 *   cc-usage-monitor set-budget <userId> <tokens>  Set per-user monthly budget
 *   cc-usage-monitor set-warn <percent>            Set warning threshold (default 80%)
 *   cc-usage-monitor reset <userId>                Reset a user's current month
 *   cc-usage-monitor reset-all                     Reset all users' current month
 *
 * Budget of 0 = unlimited. Budgets are in billable tokens
 * (input + output + cache creation, not cache reads).
 *
 * Data: ~/.ccm/usage/
 */

const fs = require("fs");
const path = require("path");
const os = require("os");

const USAGE_DIR = path.join(os.homedir(), ".ccm", "usage");
const LIMITS_FILE = path.join(USAGE_DIR, "limits.json");
fs.mkdirSync(USAGE_DIR, { recursive: true });

function loadLimits() {
  try { return JSON.parse(fs.readFileSync(LIMITS_FILE, "utf8")); }
  catch { return { default_monthly_tokens: 0, warn_percent: 80, users: {} }; }
}
function saveLimits(l) { fs.writeFileSync(LIMITS_FILE, JSON.stringify(l, null, 2)); }
function loadUsage(userId) {
  try { return JSON.parse(fs.readFileSync(path.join(USAGE_DIR, `${userId}.json`), "utf8")); }
  catch { return { userId, months: {} }; }
}
function monthKey() { return new Date().toISOString().slice(0, 7); }

function fmt(n) {
  if (n >= 1_000_000) return `${(n / 1_000_000).toFixed(1)}M`;
  if (n >= 1_000) return `${(n / 1_000).toFixed(0)}K`;
  return String(n);
}

function pct(used, limit) {
  if (limit === 0) return "—";
  return `${Math.round((used / limit) * 100)}%`;
}

// ── Commands ──

function cmdStatus() {
  const limits = loadLimits();
  const month = monthKey();
  const files = fs.readdirSync(USAGE_DIR).filter(f => f.endsWith(".json") && f !== "limits.json");

  if (files.length === 0) {
    console.log("No usage data yet.");
    return;
  }

  console.log(`\n  Monthly Usage — ${month}\n`);
  console.log(`  ${"User".padEnd(25)} ${"Input".padStart(10)} ${"Output".padStart(10)} ${"Cache Cr.".padStart(10)} ${"Billable".padStart(10)} ${"Budget".padStart(10)} ${"Used".padStart(7)} ${"Status".padStart(8)}`);
  console.log(`  ${"─".repeat(25)} ${"─".repeat(10)} ${"─".repeat(10)} ${"─".repeat(10)} ${"─".repeat(10)} ${"─".repeat(10)} ${"─".repeat(7)} ${"─".repeat(8)}`);

  for (const f of files) {
    const userId = f.replace(".json", "");
    const usage = loadUsage(userId);
    const mo = usage.months?.[month] || { input_tokens: 0, output_tokens: 0, cache_creation: 0, cache_read: 0 };
    const billable = mo.input_tokens + mo.output_tokens + mo.cache_creation;
    const userLimit = limits.users?.[userId]?.monthly_tokens ?? limits.default_monthly_tokens ?? 0;
    const limitStr = userLimit === 0 ? "none" : fmt(userLimit);
    const usedPct = pct(billable, userLimit);
    const warnPct = limits.warn_percent || 80;
    let status = "ok";
    if (userLimit > 0 && billable >= userLimit) status = "OVER";
    else if (userLimit > 0 && (billable / userLimit * 100) >= warnPct) status = "WARN";

    console.log(`  ${userId.padEnd(25)} ${fmt(mo.input_tokens).padStart(10)} ${fmt(mo.output_tokens).padStart(10)} ${fmt(mo.cache_creation).padStart(10)} ${fmt(billable).padStart(10)} ${limitStr.padStart(10)} ${usedPct.padStart(7)} ${status.padStart(8)}`);
  }
  console.log();
  console.log(`  Default budget: ${limits.default_monthly_tokens === 0 ? "unlimited" : fmt(limits.default_monthly_tokens)}/month`);
  console.log(`  Warning at: ${limits.warn_percent || 80}%`);
  console.log();
}

function cmdCheck(userId) {
  const limits = loadLimits();
  const month = monthKey();
  const usage = loadUsage(userId);
  const mo = usage.months?.[month] || { input_tokens: 0, output_tokens: 0, cache_creation: 0, cache_read: 0, daily: {} };
  const billable = mo.input_tokens + mo.output_tokens + mo.cache_creation;
  const userLimit = limits.users?.[userId]?.monthly_tokens ?? limits.default_monthly_tokens ?? 0;

  console.log(`\n  User: ${userId}`);
  console.log(`  Month: ${month}`);
  console.log(`  ──────────────────────────`);
  console.log(`  Input tokens:    ${mo.input_tokens.toLocaleString()}`);
  console.log(`  Output tokens:   ${mo.output_tokens.toLocaleString()}`);
  console.log(`  Cache creation:  ${mo.cache_creation.toLocaleString()}`);
  console.log(`  Cache read:      ${(mo.cache_read || 0).toLocaleString()}`);
  console.log(`  ──────────────────────────`);
  console.log(`  Billable total:  ${billable.toLocaleString()}`);
  console.log(`  Monthly budget:  ${userLimit === 0 ? "unlimited" : userLimit.toLocaleString()}`);
  if (userLimit > 0) {
    const remaining = Math.max(0, userLimit - billable);
    console.log(`  Used:            ${pct(billable, userLimit)}`);
    console.log(`  Remaining:       ${remaining.toLocaleString()}`);
    console.log(`  Status:          ${billable >= userLimit ? "OVER BUDGET" : "ok"}`);
  }

  // Show previous months if available
  const prevMonths = Object.keys(usage.months || {}).filter(m => m !== month).sort().reverse();
  if (prevMonths.length > 0) {
    console.log(`\n  History:`);
    for (const pm of prevMonths) {
      const pmo = usage.months[pm];
      const pb = pmo.input_tokens + pmo.output_tokens + pmo.cache_creation;
      console.log(`    ${pm}: ${fmt(pb)} billable`);
    }
  }
  console.log();
}

function cmdDaily(userId) {
  const month = monthKey();
  const usage = loadUsage(userId);
  const mo = usage.months?.[month];

  if (!mo || !mo.daily || Object.keys(mo.daily).length === 0) {
    console.log(`No daily data for ${userId} in ${month}.`);
    return;
  }

  console.log(`\n  Daily Breakdown — ${userId} — ${month}\n`);
  console.log(`  ${"Date".padEnd(14)} ${"Input".padStart(10)} ${"Output".padStart(10)} ${"Cache Cr.".padStart(10)} ${"Billable".padStart(10)}`);
  console.log(`  ${"─".repeat(14)} ${"─".repeat(10)} ${"─".repeat(10)} ${"─".repeat(10)} ${"─".repeat(10)}`);

  const days = Object.keys(mo.daily).sort();
  for (const d of days) {
    const dd = mo.daily[d];
    const billable = dd.input_tokens + dd.output_tokens + dd.cache_creation;
    if (billable === 0) continue;
    console.log(`  ${d.padEnd(14)} ${fmt(dd.input_tokens).padStart(10)} ${fmt(dd.output_tokens).padStart(10)} ${fmt(dd.cache_creation).padStart(10)} ${fmt(billable).padStart(10)}`);
  }

  const total = mo.input_tokens + mo.output_tokens + mo.cache_creation;
  console.log(`  ${"─".repeat(14)} ${"─".repeat(10)} ${"─".repeat(10)} ${"─".repeat(10)} ${"─".repeat(10)}`);
  console.log(`  ${"TOTAL".padEnd(14)} ${fmt(mo.input_tokens).padStart(10)} ${fmt(mo.output_tokens).padStart(10)} ${fmt(mo.cache_creation).padStart(10)} ${fmt(total).padStart(10)}`);
  console.log();
}

function cmdSetBudget(args) {
  const limits = loadLimits();
  if (args.length === 1) {
    limits.default_monthly_tokens = parseInt(args[0], 10);
    saveLimits(limits);
    console.log(`Default monthly budget: ${limits.default_monthly_tokens === 0 ? "unlimited" : fmt(limits.default_monthly_tokens)}`);
  } else if (args.length === 2) {
    if (!limits.users) limits.users = {};
    limits.users[args[0]] = { monthly_tokens: parseInt(args[1], 10) };
    saveLimits(limits);
    const val = limits.users[args[0]].monthly_tokens;
    console.log(`User ${args[0]} monthly budget: ${val === 0 ? "unlimited" : fmt(val)}`);
  } else {
    console.error("Usage: cc-usage-monitor set-budget [userId] <tokens>");
    process.exit(1);
  }
}

function cmdSetWarn(args) {
  if (args.length !== 1) { console.error("Usage: cc-usage-monitor set-warn <percent>"); process.exit(1); }
  const limits = loadLimits();
  limits.warn_percent = parseInt(args[0], 10);
  saveLimits(limits);
  console.log(`Warning threshold: ${limits.warn_percent}%`);
}

function cmdReset(userId) {
  const month = monthKey();
  const usage = loadUsage(userId);
  if (usage.months?.[month]) {
    delete usage.months[month];
    fs.writeFileSync(path.join(USAGE_DIR, `${userId}.json`), JSON.stringify(usage, null, 2));
  }
  console.log(`Reset ${month} usage for ${userId}`);
}

function cmdResetAll() {
  const files = fs.readdirSync(USAGE_DIR).filter(f => f.endsWith(".json") && f !== "limits.json");
  for (const f of files) cmdReset(f.replace(".json", ""));
}

// ── Main ──

const [cmd, ...args] = process.argv.slice(2);

switch (cmd) {
  case "status": cmdStatus(); break;
  case "check":
    if (!args[0]) { console.error("Usage: cc-usage-monitor check <userId>"); process.exit(1); }
    cmdCheck(args[0]); break;
  case "daily":
    if (!args[0]) { console.error("Usage: cc-usage-monitor daily <userId>"); process.exit(1); }
    cmdDaily(args[0]); break;
  case "set-budget": cmdSetBudget(args); break;
  case "set-warn": cmdSetWarn(args); break;
  case "reset":
    if (!args[0]) { console.error("Usage: cc-usage-monitor reset <userId>"); process.exit(1); }
    cmdReset(args[0]); break;
  case "reset-all": cmdResetAll(); break;
  default:
    console.log("cc-usage-monitor — Channel token usage and monthly budgets\n");
    console.log("Commands:");
    console.log("  status                       Monthly overview for all users");
    console.log("  check <userId>               Detailed usage for one user");
    console.log("  daily <userId>               Daily breakdown for current month");
    console.log("  set-budget <tokens>           Set default monthly budget (0 = unlimited)");
    console.log("  set-budget <userId> <tokens>  Set per-user monthly budget");
    console.log("  set-warn <percent>            Set warning threshold (default 80%)");
    console.log("  reset <userId>               Reset user's current month");
    console.log("  reset-all                    Reset all current month counters");
    console.log("\nData: ~/.ccm/usage/");
}
